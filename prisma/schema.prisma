generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String    @id @default(cuid())
  username  String    @unique
  password  String
  name      String?
  email     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())
  sessions  Session[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model HeroSlide {
  id          String  @id @default(cuid())
  title       String
  subtitle    String
  description String
  image       String
  sortOrder   Int     @default(0)
}

model Feature {
  id          String @id @default(cuid())
  icon        String
  title       String
  description String
  sortOrder   Int    @default(0)
}

model MenuItem {
  id          String  @id @default(cuid())
  name        String
  description String  @default("")
  price       Int
  image       String
  category    String
  badge       String?
  isFeatured  Boolean @default(false)
  sortOrder   Int     @default(0)
}

model SiteContent {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}
